# ============================================================
# GL-MT3000 (Beryl AX) OpenWrt 25.12 最终整合版
# 构建日期: 2026-03-24
# 包含：官方功能复刻 + 安全加固 + 无线中继增强 + 代理双全
# ============================================================

# [1] 硬件架构与核心驱动
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_glinet_gl-mt3000=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# 无线驱动 (MTK 闭源/开源适配)
CONFIG_PACKAGE_kmod-mt7981-firmware=y
CONFIG_PACKAGE_kmod-mt7921-common=y
CONFIG_PACKAGE_wpad-mesh-mbedtls=y
CONFIG_PACKAGE_iwinfo=y

# 核心硬件支持
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-tun=y

# [2] 官方默认防火墙 (Firewall4 + nftables)
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_nftables-json=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-mtk-eth-warp=y

# [3] 无线中继与透明桥接 (Relayd)
CONFIG_PACKAGE_relayd=y
CONFIG_PACKAGE_luci-proto-relay=y

# [4] DHCP & DNS 服务 (Full 版支持高级分流)
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_auth=y
CONFIG_PACKAGE_dnsmasq_full_conntrack=y
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_dnssec=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_dnsmasq_full_noid=y
CONFIG_PACKAGE_dnsmasq_full_tftp=y

# [5] 代理插件与广告过滤 (全量依赖)

# --- OpenClash ---
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-i18n-openclash-zh-cn=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-bin=y
CONFIG_PACKAGE_ruby=y
CONFIG_PACKAGE_ruby-yaml=y

# --- Passwall (适配 Firewall4/nftables) ---
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_passwall_Nftables_Transparent_Proxy=y
CONFIG_PACKAGE_passwall_Xray=y
CONFIG_PACKAGE_passwall_Trojan_Plus=y
CONFIG_PACKAGE_passwall_NaiveProxy=y
CONFIG_PACKAGE_passwall_Hysteria=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_dns2tcp=y
CONFIG_PACKAGE_tcping=y

# --- Adblock Fast ---
CONFIG_PACKAGE_luci-app-adblock-fast=y
CONFIG_PACKAGE_luci-i18n-adblock-fast-zh-cn=y

# [6] 复刻官方核心功能 (NAS / 组网 / 调优)
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-app-openvpn=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-exfat=y

# [7] SSH 安全加固 (端口 2222，强制密钥)
CONFIG_DROPBEAR_PORT=2222
CONFIG_DROPBEAR_DISABLE_PASSWORD_AUTH=y
CONFIG_DROPBEAR_DISABLE_ROOT_PASSWORD=y
CONFIG_DROPBEAR_ECC=y
CONFIG_DROPBEAR_CURVE25519=y
CONFIG_DROPBEAR_CHACHA20POLY1305=y

# [8] 内核性能与网络优化 (BBR)
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_KERNEL_DEFAULT_TCP_CONG="bbr"
CONFIG_KERNEL_STACKPROTECTOR_STRONG=y
CONFIG_KERNEL_SYN_COOKIES=y
CONFIG_KERNEL_REFCOUNT_FULL=y

# [9] 界面、语言与 25.12 必备组件
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_apk-openssl=y
